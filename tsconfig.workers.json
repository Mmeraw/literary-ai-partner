{
  "compilerOptions": {
    "lib": ["ES2020"],
    "moduleResolution": "node16",
    "module": "node16",
    "target": "ES2020",
    "outDir": "./dist-workers",
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["workers/**/*.ts", "types/providerCalls.ts"],
  "exclude": ["node_modules", ".next"]
}
