{
  "name": "revisiongrade",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "pretest": "node scripts/guard-critical-tests.mjs",
    "dev": "next dev -p 3002",
    "build": "npm run spine:verify && npm run docs:runtime:guard && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "canon:guard": "bash ./scripts/canon-guard.sh",
    "spine:verify": "bash scripts/verify-spine.sh",
    "config:validate": "node scripts/validate-production-config.mjs",
    "docs:verify": "bash scripts/verification-contract.sh",
    "docs:runtime:guard": "bash scripts/verify-canonical-runtime-authority.sh",
    "verify:zero-drift": "bash scripts/verify-zero-drift.sh",
    "guard:clean-tree": "bash scripts/guard-clean-tree.sh",
    "test": "jest",
    "test:ci": "jest --silent",
    "test:polling": "jest --testPathPatterns=polling",
    "test:staging": "DOTENV_CONFIG_PATH=.env.test.local node -r dotenv/config node_modules/.bin/jest",
    "test:staging:chunks": "DOTENV_CONFIG_PATH=.env.test.local node -r dotenv/config node_modules/.bin/jest tests/manuscript-chunks-stability.test.ts",
    "jobs:smoke": "node scripts/jobs-smoke.mjs",
    "jobs:smoke:phase2": "node scripts/jobs-smoke-phase2.mjs",
    "jobs:smoke:real": "node scripts/jobs-smoke-real.mjs",
    "jobs:smoke:supabase": "node scripts/jobs-supabase-contract-smoke.mjs",
    "jobs:admin-retry:concurrency": "node scripts/jobs-admin-retry-concurrency.mjs",
    "jobs:check-migrations": "node scripts/check-ci-db-migrations.mjs",
    "jobs:validate": "node scripts/jobs-validate-invariants.mjs",
    "jobs:test:resume": "node scripts/jobs-phase2-resume-test.mjs",
    "jobs:test:contention": "node scripts/jobs-lease-contention-test.mjs",
    "jobs:test:cancel": "node scripts/jobs-test-cancel.mjs",
    "jobs:test:retry": "node scripts/jobs-test-retry-backoff.mjs",
    "jobs:test:metrics": "node scripts/jobs-test-metrics.mjs",
    "jobs:retry-tick": "node scripts/jobs-retry-tick.mjs",
    "jobs:load": "node scripts/jobs-load.mjs",
    "soak:run": "tsx -r tsconfig-paths/register scripts/soak/run-soak.ts",
    "soak:debug": "npm run soak:run -- --events=1000 --concurrency=5 --seed=42 --mode=deterministic",
    "soak:stability": "npm run soak:run -- --events=10000 --concurrency=10 --seed=42 --mode=stress",
    "soak:qualify": "npm run soak:run -- --events=100000 --concurrency=10 --seed=42 --mode=stress",
    "revision:hydrate:stage2": "node scripts/revision-stage2-hydrate.mjs",
    "revision:smoke:stage2": "node scripts/revision-stage2-smoke.mjs",
    "evidence:phase2c": "bash scripts/evidence-phase2c.sh",
    "evidence:phase2d": "bash scripts/evidence-phase2d.sh",
    "evidence:flow1": "bash scripts/evidence-flow1.sh",
    "a6:run": "tsx -r tsconfig-paths/register scripts/a6/run-a6-evidence.ts",
    "phase2.7:real-run": "tsx -r tsconfig-paths/register scripts/pipeline/run-phase2-7-real-run.ts",
    "phase2.7:dominatus-harness": "tsx -r tsconfig-paths/register scripts/pipeline/run-dominatus-i4-eval.ts"
  },
