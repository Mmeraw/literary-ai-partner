#env
.env
.env.*

# Logs
logs/**
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Canonical proof-artifact exceptions under logs/
# Double-unignore required: un-ignore directory first, re-ignore its contents,
# then selectively un-ignore specific canonical files.
!logs/u2-live-proof/
logs/u2-live-proof/**
!logs/u2-live-proof/RUN_NOTES.md
!logs/u2-live-proof/u2-proof-*.json
!logs/u2-live-proof/u2-proof-*.validation.txt
!logs/u2-live-proof/u2-artifact-verification-*.json
!logs/u2-live-proof/job-row-*.json
!logs/u2-live-proof/artifact-raw-*.json
!logs/u2-live-proof/artifacts-*.json

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env
# # Next.js build output
.next
out

.env.local
.env.test.local
!.env.test.example

# Local scratch/build artifacts
/tmp-*.json
/tsconfig.tsbuildinfo
/tmp/
*.tsbuildinfo
dist-workers/
docs/operations/evidence/runs/*
!docs/operations/evidence/runs/*_README.md
!docs/operations/evidence/runs/*/
docs/operations/evidence/runs/*/*
!docs/operations/evidence/runs/*/metadata.json
!docs/operations/evidence/runs/*/quality_gate.json

# Local/accidental
your-repo.git/
revisiongrade-governance.bundle
*.bundle

# Prevent accidental nested git dirs
**/.git/

# Local git worktrees (never commit)
.worktrees/

# Local security remediation notes (do not commit)
CI_SECRETS_FIX_*.md
SECRETS_FIX_*.md
SECURITY_*.md
scripts/inspect-jwt.js
scripts/verify-secrets-alignment.sh
.dev-server.pid
.vercel
.env*.local

# Canon raw source files (originals live in Drive)
# Production canon/RAG loads docs/canon/registered/** only.
# Intake canon is non-binding by default.
# docs/canon/intake/** may load only with explicit INTAKE_MODE=true
# .docx originals are backed up 3-2-1 (OneDrive + external disk + laptop).
docs/canon/intake/_raw/

# --- repo hygiene PR-0 ---
node_modules/
**/node_modules/
.next/
dist/
build/
coverage/
worktrees/
.worktrees/
*.log
.env*.local

# Pipeline stress harness output (artifact-only; .gitkeep tracked)
stress-results/*
!stress-results/.gitkeep
