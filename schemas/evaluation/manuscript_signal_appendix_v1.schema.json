{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://revisiongrade.com/schema/manuscript_signal_appendix_v1.json",
  "title": "manuscript_signal_appendix_v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "job_id",
    "evaluation_project_id",
    "manuscript_id",
    "manuscript_version_hash",
    "artifact_id",
    "artifact_type",
    "artifact_version",
    "source_hash",
    "generated_at",
    "accepted_story_ledger_artifact_id",
    "accepted_story_ledger_source_hash",
    "status",
    "warnings"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "evaluation_project_id": { "type": ["string", "null"] },
    "stage_run_id": { "type": ["string", "null"] },
    "manuscript_id": { "type": "number" },
    "manuscript_version_hash": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "manuscript_signal_appendix_v1" },
    "artifact_version": { "type": "string", "minLength": 1 },
    "source_hash": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "accepted_story_ledger_artifact_id": { "type": "string", "minLength": 1 },
    "accepted_story_ledger_source_hash": { "type": "string", "minLength": 1 },
    "status": { "enum": ["complete", "partial", "degraded", "failed"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "authority": { "type": "object" },
    "dialogue_narrative_ratio": { "type": "object" },
    "readability_stats": { "type": "object" },
    "repetition_scan": { "type": "object" },
    "style_density": { "type": "object" },
    "content_and_market_signals": { "type": "object" }
  }
}
