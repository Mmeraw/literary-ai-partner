{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://revisiongrade.com/schema/revision_opportunity_ledger_v1.json",
  "title": "revision_opportunity_ledger_v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "job_id",
    "manuscript_id",
    "manuscript_version_hash",
    "artifact_id",
    "artifact_type",
    "artifact_version",
    "source_hash",
    "generated_at",
    "opportunity_source_authority",
    "quality_manifest",
    "revise_queue_preflight",
    "opportunities"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "evaluation_project_id": { "type": ["string", "null"] },
    "manuscript_id": { "type": "number", "exclusiveMinimum": 0 },
    "manuscript_version_hash": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "revision_opportunity_ledger_v1" },
    "artifact_version": { "type": "string", "minLength": 1 },
    "source_hash": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "opportunity_source_authority": { "type": "string", "minLength": 1 },
    "quality_manifest": {
      "type": "object",
      "required": ["dcip_compliance", "constitutional_authority_registry"],
      "properties": {
        "dcip_compliance": { "type": "object" },
        "constitutional_authority_registry": { "type": "object" }
      }
    },
    "revise_queue_preflight": { "type": "object" },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "opportunity_id",
          "finding_id",
          "criterion",
          "severity",
          "rationale",
          "evidence_anchor",
          "manuscript_coordinates",
          "provenance",
          "confidence",
          "decision_state",
          "revision_operation",
          "preflight_status",
          "grounding_status"
        ],
        "properties": {
          "opportunity_id": { "type": "string", "minLength": 1 },
          "finding_id": { "type": "string", "minLength": 1 },
          "criterion": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["must", "should", "could"] },
          "rationale": { "type": "string", "minLength": 1 },
          "evidence_anchor": { "type": "string", "minLength": 1 },
          "manuscript_coordinates": { "type": "string", "minLength": 1 },
          "provenance": { "type": "string", "minLength": 1 },
          "confidence": { "enum": ["low", "medium", "high"] },
          "decision_state": { "const": "open" },
          "revision_operation": {
            "enum": [
              "replace_selected_passage",
              "insert_before_selected_passage",
              "insert_after_selected_passage",
              "rewrite_full_paragraph",
              "rewrite_multi_paragraph_span",
              "compress_selected_passage",
              "delete_selected_passage",
              "split_paragraph",
              "merge_paragraphs",
              "reorder_within_section",
              "needs_targeting"
            ]
          },
          "preflight_status": { "enum": ["passed", "limited_context", "blocked"] },
          "grounding_status": {
            "enum": [
              "supported",
              "supported_after_relook",
              "unsupported_blocked",
              "uncertain_after_relook_reportable",
              "uncertain_after_relook_blocked"
            ]
          }
        }
      }
    }
  }
}
