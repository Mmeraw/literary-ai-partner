{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://revisiongrade.com/schema/pass1a_story_layer_v1.json",
  "title": "pass1a_story_layer_v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "job_id",
    "evaluation_project_id",
    "manuscript_id",
    "manuscript_version_hash",
    "artifact_id",
    "artifact_type",
    "artifact_version",
    "source_hash",
    "generated_at",
    "source_integrity_layer",
    "pov_structure_layer",
    "canonical_identity_layer",
    "cast_role_tier_layer",
    "relationship_network_layer",
    "object_symbol_layer",
    "location_timeline_worldstate_layer",
    "threat_antagonist_ending_layer"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "evaluation_project_id": { "type": ["string", "null"] },
    "stage_run_id": { "type": ["string", "null"] },
    "manuscript_id": { "type": "number" },
    "manuscript_version_hash": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "pass1a_story_layer_v1" },
    "artifact_version": { "type": "string", "minLength": 1 },
    "source_hash": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "source_integrity_layer": { "type": "object" },
    "pov_structure_layer": { "type": "object" },
    "canonical_identity_layer": { "type": "object" },
    "cast_role_tier_layer": { "type": "object" },
    "relationship_network_layer": { "type": "object" },
    "object_symbol_layer": { "type": "object" },
    "location_timeline_worldstate_layer": { "type": "object" },
    "threat_antagonist_ending_layer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["narrative_pressure_vectors"],
      "properties": {
        "narrative_pressure_vectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["vector_source", "evidence_summary", "structural_impact_score"],
            "properties": {
              "vector_source": {
                "type": "string",
                "enum": [
                  "person",
                  "institution",
                  "environment",
                  "illness",
                  "internal_contradiction",
                  "social_pressure",
                  "trauma",
                  "fate_mortality",
                  "secrecy",
                  "poverty",
                  "systemic_constraint",
                  "family_obligation"
                ]
              },
              "evidence_summary": { "type": "string", "minLength": 20 },
              "structural_impact_score": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          }
        }
      }
    }
  }
}
